// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EquipmentType {
  BARBELL
  DUMBBELL
  KETTLEBELL
  MACHINE
  BODYWEIGHT
  CABLE
}

enum MovementType {
  PUSH
  PULL
  SQUAT
  HINGE
  LUNGE
  ROTATION
  CARRY
  ISOMETRIC
}

enum PreferredUnits {
  METRIC
  IMPERIAL
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
}

enum WorkoutStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum WorkoutIntensity {
  LIGHT
  MODERATE
  VIGOROUS
}

enum CalorieSource {
  ESTIMATED
  OVERRIDDEN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  PRE_WORKOUT
  POST_WORKOUT
  OTHER
}

enum TemplateVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum TemplateDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum HealthStatus {
  ACTIVE
  MANAGED
  RESOLVED
}

enum InjuryStatus {
  ACTIVE
  RECOVERING
  RESOLVED
}

enum InjurySide {
  LEFT
  RIGHT
  BILATERAL
  NOT_APPLICABLE
}

enum AchievementCategory {
  WORKOUT
  STREAK
  NUTRITION
  VOLUME
  COMMUNITY
}

model User {
  id        String  @id @default(uuid())
  name      String?
  email     String  @unique
  avatarUrl String?

  profile           UserProfile?
  workouts          Workout[]
  nutritionEntries  NutritionEntry[]
  weightCheckIns    WeightCheckIn[]
  medicalConditions MedicalCondition[]
  injuries          Injury[]
  templates         WorkoutTemplate[]
  templateCopies    TemplateCopy[]     @relation("TemplateCopyRecipient")
  achievements      UserAchievement[]
  activityDays      UserActivityDay[]
  adminAccess       AdminAccess?
  adminAuditLogs    AdminAuditLog[]    @relation("AdminAuditActor")
  updatedAt         DateTime           @updatedAt
  createdAt         DateTime           @default(now())
}

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String

  age      Int
  gender   String
  heightCm Int
  weightKg Float
  goal     String

  activityLevel        ActivityLevel  @default(MODERATELY_ACTIVE)
  dailyCalorieTarget   Int            @default(2000)
  targetWeightKg       Float?
  preferredUnits       PreferredUnits @default(METRIC)
  timezone             String         @default("UTC")
  weeklyWorkoutTarget  Int            @default(3)
  preferredWorkoutDays Int[]          @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workout {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                   String? // e.g. "Push Day", "Legs A"
  date                    DateTime // workout date
  durationM               Int? // total duration in minutes
  notes                   String?
  status                  WorkoutStatus    @default(DRAFT)
  startedAt               DateTime?
  completedAt             DateTime?
  intensity               WorkoutIntensity @default(MODERATE)
  perceivedDifficulty     Int?
  estimatedCaloriesBurned Int?
  caloriesBurned          Int?
  calorieSource           CalorieSource?
  templateId              String?
  template                WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  exercises WorkoutExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date, status])
}

model Exercise {
  id String @id @default(uuid())

  name      String // "Barbell Bench Press"
  equipment EquipmentType
  movement  MovementType
  category  String // Chest, Back, Legs, Shoulders, Arms, Core
  region    String? // Upper chest, Lats, Quads, etc.

  isCompound            Boolean  @default(true)
  instructions          String?
  imageUrl              String?
  secondaryMuscleGroups String[] @default([])
  safetyNotes           String?
  contraindicationTags  String[] @default([])
  isArchived            Boolean  @default(false)

  workouts          WorkoutExercise[]
  templateExercises TemplateExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, equipment])
}

model WorkoutExercise {
  id         String @id @default(uuid())
  workoutId  String
  exerciseId String

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  order Int // order in workout (1,2,3...)

  sets WorkoutSet[]

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workoutId])
}

model WorkoutSet {
  id                String @id @default(uuid())
  workoutExerciseId String

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  setNumber     Int
  reps          Int?
  weightKg      Float?
  durationS     Int?
  distanceM     Int?
  rpe           Float?
  isCompleted   Boolean @default(false)
  restDurationS Int?

  createdAt DateTime @default(now())

  @@index([workoutExerciseId])
}

model AdminAccess {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model NutritionEntry {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumedAt      DateTime
  mealType        MealType
  foodName        String
  calories        Int
  proteinG        Float?
  carbsG          Float?
  fatG            Float?
  fibreG          Float?
  servingQuantity Float?
  servingUnit     String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, consumedAt])
}

model WeightCheckIn {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordedAt DateTime
  weightKg   Float
  notes      String?
  createdAt  DateTime @default(now())

  @@index([userId, recordedAt])
}

model MedicalCondition {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  status            HealthStatus @default(ACTIVE)
  severity          String?
  startedAt         DateTime?
  resolvedAt        DateTime?
  clinicianGuidance String?
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([userId, status])
}

model Injury {
  id                   String       @id @default(uuid())
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bodyRegion           String
  name                 String
  side                 InjurySide   @default(NOT_APPLICABLE)
  status               InjuryStatus @default(ACTIVE)
  painLevel            Int?
  startedAt            DateTime?
  resolvedAt           DateTime?
  notes                String?
  exercisesToAvoid     String[]     @default([])
  contraindicationTags String[]     @default([])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([userId, status])
}

model WorkoutTemplate {
  id                 String             @id @default(uuid())
  ownerId            String
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  goal               String?
  difficulty         TemplateDifficulty @default(BEGINNER)
  estimatedDurationM Int?
  visibility         TemplateVisibility @default(PRIVATE)
  tags               String[]           @default([])
  shareToken         String?            @unique
  isArchived         Boolean            @default(false)
  copyCount          Int                @default(0)
  useCount           Int                @default(0)
  exercises          TemplateExercise[]
  workouts           Workout[]
  sourceCopies       TemplateCopy[]     @relation("TemplateCopySource")
  copiedRecord       TemplateCopy?      @relation("TemplateCopyResult")
  useEvents          TemplateUseEvent[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([ownerId, isArchived])
  @@index([visibility, createdAt])
}

model TemplateExercise {
  id                String          @id @default(uuid())
  templateId        String
  template          WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseId        String
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])
  order             Int
  targetSets        Int             @default(3)
  minReps           Int?
  maxReps           Int?
  suggestedWeightKg Float?
  targetRpe         Float?
  restSeconds       Int?
  notes             String?

  @@index([templateId, order])
}

model TemplateCopy {
  id               String          @id @default(uuid())
  sourceTemplateId String
  sourceTemplate   WorkoutTemplate @relation("TemplateCopySource", fields: [sourceTemplateId], references: [id], onDelete: Cascade)
  recipientId      String
  recipient        User            @relation("TemplateCopyRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  copiedTemplateId String          @unique
  copiedTemplate   WorkoutTemplate @relation("TemplateCopyResult", fields: [copiedTemplateId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())

  @@index([recipientId, createdAt])
  @@index([createdAt])
}

model UserActivityDay {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityDate  DateTime @db.Date
  firstActiveAt DateTime
  lastActiveAt  DateTime
  requestCount  Int      @default(1)

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model TemplateUseEvent {
  id                    String           @id @default(uuid())
  templateId            String?
  template              WorkoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateTitleSnapshot String
  createdAt             DateTime         @default(now())

  @@index([createdAt])
  @@index([templateId, createdAt])
}

model Achievement {
  id           String              @id @default(uuid())
  key          String              @unique
  name         String
  description  String
  category     AchievementCategory
  icon         String
  criteria     Json
  displayOrder Int                 @default(0)
  isActive     Boolean             @default(true)
  users        UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  awardedAt     DateTime    @default(now())
  context       Json?

  @@unique([userId, achievementId])
  @@index([userId, awardedAt])
  @@index([awardedAt])
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  actorId   String
  actor     User     @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
}
